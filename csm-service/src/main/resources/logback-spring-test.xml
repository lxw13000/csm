<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CSM · 测试 / 预发环境 Logback 配置
  · 由 application-test.yml 的 logging.config 指定加载。
  · 相比生产：控制台彩色输出（便于 QA / 联调人工观察）、保留天数更短，
    业务包级别由 application-test.yml 调到 DEBUG。
  · 日志目录默认与 jar 同级的 logs/ 目录（由启动类 CsmApplication 设置系统属性 LOG_HOME，
    无需配置 CSM_LOG_DIR 等环境变量，避免部署时遗漏）。
  · 级别最终以 application-test.yml 的 logging.level.* 为准。
  ============================================================================
-->
<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="csm-service"/>
    <!-- 日志目录：默认取启动类设置的 LOG_HOME（jar 同级 logs/）；未设置时回退为相对路径 logs -->
    <property name="LOG_DIR" value="${LOG_HOME:-logs}"/>

    <!-- 文件输出格式（无色）-->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
    <!-- 控制台彩色格式（仅测试环境，便于人工观察；着色不写入文件）-->
    <property name="CONSOLE_PATTERN"
              value="%yellow(%d{yyyy-MM-dd HH:mm:ss.SSS}) [%thread] %highlight(%-5level) %green(%logger{36}) - %msg%n"/>

    <!-- ===================== 控制台（彩色）===================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===================== 全量滚动文件 ===================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>7</maxHistory>             <!-- 测试环境保留 7 天即可 -->
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===================== 错误日志单独文件 ===================== -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===================== 异步包装 ===================== -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE"/>
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- ===================== 第三方框架日志级别（降噪；仅声明本项目实际使用的框架）=====================
         测试环境业务包 com.tsd.csm 为 DEBUG（见 application-test.yml），这些框架仍保持 INFO，
         使业务调试日志更突出。最终级别仍以 application-test.yml 的 logging.level.* 为准。
    -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.apache.ibatis" level="INFO"/>
    <logger name="com.baomidou.mybatisplus" level="INFO"/>
    <logger name="io.lettuce.core" level="INFO"/>
    <logger name="com.zaxxer.hikari" level="INFO"/>

    <!-- ===================== 根日志：基线 INFO（业务包级别由 yml 调到 DEBUG）===================== -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
